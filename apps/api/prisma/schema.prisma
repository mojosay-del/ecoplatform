generator client {
  provider = "prisma-client-js"
  // native       — локальная разработка (macOS arm64 / linux x64).
  // linux-musl-* — alpine-образы в Docker (наш прод-вариант).
  // debian-*     — запасной вариант, если перейдём на bookworm-slim.
  // Без этого `prisma generate` в Docker не подтянет нужный query engine.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  demo
  active
  past_due
  suspended
  blocked
  archived
}

enum SubscriptionPlan {
  basic
  extended
}

enum SubscriptionStatus {
  active
  past_due
  suspended
  cancelled
  expired
}

enum CompanyType {
  collector
  trader
  processor
}

enum UserGender {
  male
  female
}

enum PlatformRole {
  admin
  moderator
  content_manager
}

enum ContentStatus {
  draft
  published
}

enum LearningAccessLevel {
  basic
  extended
  one_time
}

enum SupportTicketStatus {
  new
  in_progress
  awaiting_user
  resolved
  closed
}

enum SupportTicketCategory {
  billing
  moderation_review
  company_management
  technical
  data_deletion
  other
}

enum CommentStatus {
  published
  hidden_by_moderator
  removed_by_admin
  removed_with_news
}

enum FileAccessLevel {
  public
  authenticated
  platform_private
  conversation_private
}

enum NotificationCategory {
  security
  billing
  marketplace
  moderation
  support
  system
}

enum NotificationChannel {
  in_app
  email
  sms
}

enum NotificationDeliveryStatus {
  queued
  in_progress
  delivered
  failed
  retry_scheduled
  dead_lettered
  no_recipients
}

enum ModerationCaseType {
  complaint
  suspicious_activity
}

enum ModerationCaseStatus {
  open
  in_review
  resolved
  escalated
  closed_by_admin
}

enum ComplaintStatus {
  pending
  resolved
  auto_closed
}

enum ModerationDecisionType {
  leave_as_is
  remove_content
  warn_company
  escalate_to_admin
}

enum SanctionType {
  warning
  content_removal
  module_restriction
  user_block
  company_block
}

enum UserStatus {
  active
  blocked
}

enum LegalDocumentType {
  privacy_policy
  terms_of_service
  personal_data_consent
  cookie_policy
  marketing_consent
  offer_agreement
}

enum ConsentSource {
  registration
  login_reconfirm
  cookie_banner
  settings
  admin_action
}

// Полиморфные обсуждения: ветка комментариев привязывается не к конкретной
// сущности (NewsPost), а к Discussion с парой (targetType, targetId).
// Это позволяет лениво подключать комментарии к урокам, статьям базы знаний,
// объявлениям торговой площадки и темам форума без расщепления Comment.
enum DiscussionTargetType {
  news_post
  lesson
  knowledge_article
  listing
  forum_thread
  solution_review
}

model User {
  id                      String                       @id @default(cuid())
  email                   String                       @unique
  phone                   String                       @unique
  firstName               String
  lastName                String
  gender                  UserGender                   @default(male)
  passwordHash            String
  status                  UserStatus                   @default(active)
  companyId               String?
  company                 Company?                     @relation(fields: [companyId], references: [id])
  platformStaff           PlatformStaff?
  sessions                Session[]
  newsLikes               NewsLike[]
  comments                Comment[]
  commentLikes            CommentLike[]
  lessonProgress          LessonProgress[]
  supportTickets          SupportTicket[]              @relation("SupportTicketAuthor")
  notifications           InAppNotification[]
  notificationDeliveries  NotificationDelivery[]       @relation("NotificationRecipient")
  notificationPreferences UserNotificationPreferences?
  moduleRestrictions      UserModuleRestriction[]
  consents                ConsentRecord[]
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt

  @@index([status])
}

model Company {
  id                       String            @id @default(cuid())
  organizationName         String
  type                     CompanyType       @default(collector)
  status                   CompanyStatus     @default(demo)
  demoEndsAt               DateTime?
  subscriptionPlan         SubscriptionPlan?
  subscriptionEndsAt       DateTime?
  billingInn               String?
  billingKpp               String?
  // Старое текстовое поле legalAddress оставлено для обратной совместимости
  // (на форму биллинга, где адрес показывается как одна строка). Полноценная
  // структура адреса — в Address (factualAddress/legalAddress relation'ами).
  legalAddress             String?
  factualAddressId         String?           @unique
  factualAddress           Address?          @relation("CompanyFactualAddress", fields: [factualAddressId], references: [id])
  structuredLegalAddressId String?           @unique
  structuredLegalAddress   Address?          @relation("CompanyStructuredLegalAddress", fields: [structuredLegalAddressId], references: [id])
  // Контакты компании. Все опциональные, заполняются в /account → Компания.
  websiteUrl               String?
  corporatePhone           String?
  corporateEmail           String?
  about                    String?
  logoFileId               String?
  // Контактное лицо: если у компании назначен «менеджер по входящим обращениям»
  // отличный от первого зарегистрированного user'а. В MVP — просто текстовые поля.
  contactPersonName        String?
  contactPersonPhone       String?
  contactPersonEmail       String?
  bankName                 String?
  bankBik                  String?
  bankAccount              String?
  correspondentAccount     String?
  users                    User[]
  subscriptions            Subscription[]
  supportTickets           SupportTicket[]
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
}

// Address — самостоятельная сущность для адресов: и фактических, и юридических,
// и в перспективе адресов складов/филиалов/доставки/листингов торговой площадки.
// Хранит и raw-структуру (страна, регион, город, улица, дом, кв., индекс),
// и одну `formatted`-строку для отображения, и координаты под карту.
//
// source: 'manual' — пользователь ввёл руками; 'yandex'/'dadata' — пришло
// из подсказки автокомплита (Волна 11+); 'legacy' — миграция старого
// текстового Company.legalAddress в одну `formatted`-строку.
model Address {
  id        String   @id @default(cuid())
  country   String   @default("Россия")
  region    String?
  city      String
  street    String?
  building  String?
  apartment String?
  postcode  String?
  // Координаты (Decimal(10,7) — точность до ~1 см, хватит и под Яндекс-карту,
  // и под кадастровые расчёты).
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  // Одна строка для UI — собирается из полей при сохранении или приходит
  // из автокомплита как авторитетное значение.
  formatted String
  source    String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyAsFactual Company? @relation("CompanyFactualAddress")
  companyAsLegal   Company? @relation("CompanyStructuredLegalAddress")
}

model Subscription {
  id        String             @id @default(cuid())
  companyId String
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(active)
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  // Биллинг-cron каждый час смотрит истёкшие подписки + у компании показывает
  // самую свежую («take: 1, orderBy createdAt desc»). Оба запроса попадают
  // под этот индекс.
  @@index([companyId, createdAt(sort: Desc)])
  @@index([status, endsAt])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  rememberMe       Boolean   @default(false)
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model PlatformStaff {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles     PlatformRole[]
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model AdminActionLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  comment    String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([entityType, createdAt])
  @@index([actorId, createdAt])
}

model IdempotencyKey {
  id            String   @id @default(cuid())
  key           String
  endpoint      String
  action        String
  actorId       String
  requestHash   String
  response      Json?
  referenceType String?
  referenceId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([key, endpoint, actorId])
  @@index([endpoint, createdAt])
  @@index([actorId, createdAt])
  @@index([referenceType, referenceId])
}

model PlatformSetting {
  key           String   @id
  value         Json
  updatedById   String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model FileAsset {
  id           String          @id @default(cuid())
  originalName String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  accessLevel  FileAccessLevel @default(authenticated)
  uploadedById String?
  createdAt    DateTime        @default(now())
  references   FileReference[]
}

// Полиморфная таблица «кто на какой файл ссылается». Заменяет старый
// scan всех NewsContentBlock/LessonContentBlock/KnowledgeBaseBlock в
// `deleteIfUnreferenced` — теперь это `count({ where: { fileId } })`.
//
// Поддерживается сервисами явно через `FilesService.replaceFileReferences()`.
// На прод-стенде заполняется backfill'ом при первом запуске (если таблица
// пустая, но есть существующий контент).
model FileReference {
  id         String   @id @default(cuid())
  fileId     String
  file       FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)
  // 'news_post' | 'learning_module' | 'lesson' | 'knowledge_base_article' | 'comment'
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  // Один файл может быть упомянут только один раз в рамках одной сущности;
  // повторные ссылки внутри блоков схлопываются в одну строку.
  @@unique([fileId, entityType, entityId])
  @@index([fileId])
  @@index([entityType, entityId])
}

model NewsPost {
  id               String             @id @default(cuid())
  title            String
  lead             String
  coverImageId     String?
  slug             String             @unique
  status           ContentStatus      @default(draft)
  firstPublishedAt DateTime?
  createdById      String
  blocks           NewsContentBlock[]
  tags             NewsPostTag[]
  likes            NewsLike[]
  // Комментарии хранятся в Discussion(targetType=news_post, targetId=NewsPost.id).
  // FK прямого NewsPost↔Comment не существует — каскад удаления реализован в
  // news.service.ts (Discussion удаляется до NewsPost.delete).
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Главный публичный запрос — лента: `where status=published, orderBy firstPublishedAt desc`.
  // Без этого индекса Postgres сканирует всю таблицу новостей.
  @@index([status, firstPublishedAt(sort: Desc)])
  // Админка использует `orderBy updatedAt desc` — отдельный составной индекс.
  @@index([updatedAt(sort: Desc)])
}

model NewsContentBlock {
  id         String   @id @default(cuid())
  newsPostId String
  newsPost   NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  position   Int
  type       String
  payload    Json

  @@unique([newsPostId, position])
}

model NewsTag {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  createdById String?
  usageCount  Int           @default(0)
  posts       NewsPostTag[]
  createdAt   DateTime      @default(now())
}

model NewsPostTag {
  newsPostId String
  newsTagId  String
  newsPost   NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  newsTag    NewsTag  @relation(fields: [newsTagId], references: [id], onDelete: Cascade)
  addedAt    DateTime @default(now())

  @@id([newsPostId, newsTagId])
}

model NewsLike {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newsPostId String
  newsPost   NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, newsPostId])
}

model Discussion {
  id         String               @id @default(cuid())
  targetType DiscussionTargetType
  targetId   String
  isLocked   Boolean              @default(false)
  comments   Comment[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([targetType, targetId])
  @@index([targetType, targetId])
}

model Comment {
  id              String              @id @default(cuid())
  discussionId    String
  discussion      Discussion          @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parentCommentId String?
  parentComment   Comment?            @relation("CommentThread", fields: [parentCommentId], references: [id])
  replies         Comment[]           @relation("CommentThread")
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  text            String
  status          CommentStatus       @default(published)
  attachments     CommentAttachment[]
  likes           CommentLike[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Главный запрос — дерево комментариев обсуждения: фильтрация по
  // (discussionId, parentCommentId=null, status=published), затем reply'ы.
  @@index([discussionId, parentCommentId, status, createdAt(sort: Desc)])
  @@index([parentCommentId, status, createdAt])
}

model CommentAttachment {
  id        String  @id @default(cuid())
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  fileId    String
  position  Int

  @@unique([commentId, position])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
}

model NomenclatureCategory {
  id            String         @id @default(cuid())
  name          String         @unique
  slug          String         @unique
  position      Int            @unique
  isActive      Boolean        @default(true)
  nomenclatures Nomenclature[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Nomenclature {
  id          String               @id @default(cuid())
  code        String               @unique
  name        String
  unit        String               @default("₽/т")
  description String?
  categoryId  String
  category    NomenclatureCategory @relation(fields: [categoryId], references: [id])
  isActive    Boolean              @default(true)
  priceIndex  PriceIndex?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model PriceIndex {
  id               String            @id @default(cuid())
  nomenclatureId   String            @unique
  nomenclature     Nomenclature      @relation(fields: [nomenclatureId], references: [id], onDelete: Cascade)
  description      String?
  status           ContentStatus     @default(draft)
  firstPublishedAt DateTime?
  createdById      String
  values           PriceIndexValue[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // /indices фильтрует по `status=published` через `nomenclatures.where`.
  @@index([status])
}

model PriceIndexValue {
  id           String     @id @default(cuid())
  priceIndexId String
  priceIndex   PriceIndex @relation(fields: [priceIndexId], references: [id], onDelete: Cascade)
  date         DateTime
  price        Decimal    @db.Decimal(12, 2)
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([priceIndexId, date])
}

model LearningModule {
  id               String                 @id @default(cuid())
  title            String
  summary          String
  description      String
  coverImageId     String?
  accessLevel      LearningAccessLevel    @default(basic)
  oneTimePrice     Int?
  isInDevelopment  Boolean                @default(false)
  position         Int                    @default(0)
  status           ContentStatus          @default(draft)
  firstPublishedAt DateTime?
  createdById      String
  preview          LearningModulePreview?
  chapters         Chapter[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  // /education/modules: `where status=published, orderBy [position, createdAt]`.
  @@index([status, position])
}

model LearningModulePreview {
  id                     String         @id @default(cuid())
  moduleId               String         @unique
  module                 LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  promotionalDescription String
  whatYouWillLearn       String[]
  updatedAt              DateTime       @updatedAt
}

model Chapter {
  id          String         @id @default(cuid())
  moduleId    String
  module      LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  position    Int
  createdById String?
  lessons     Lesson[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt

  @@unique([moduleId, position])
}

model Lesson {
  id               String               @id @default(cuid())
  chapterId        String
  chapter          Chapter              @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  title            String
  position         Int
  status           ContentStatus        @default(draft)
  firstPublishedAt DateTime?
  createdById      String?
  blocks           LessonContentBlock[]
  attachments      LessonAttachment[]
  progress         LessonProgress[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([chapterId, position])
}

model LessonContentBlock {
  id       String @id @default(cuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  position Int
  type     String
  payload  Json

  @@unique([lessonId, position])
}

model LessonAttachment {
  id          String @id @default(cuid())
  lessonId    String
  lesson      Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  fileId      String
  displayName String
  position    Int

  @@unique([lessonId, position])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
}

model KnowledgeBaseArticle {
  id               String                 @id @default(cuid())
  parentId         String?
  parent           KnowledgeBaseArticle?  @relation("KnowledgeBaseTree", fields: [parentId], references: [id])
  children         KnowledgeBaseArticle[] @relation("KnowledgeBaseTree")
  title            String
  subtitle         String?
  coverImageId     String?
  slug             String                 @unique
  position         Int
  iconType         String?
  status           ContentStatus          @default(draft)
  firstPublishedAt DateTime?
  createdById      String
  blocks           KnowledgeBaseBlock[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  // Tree-выдача: парентом сортируем по position, фильтруем по status.
  @@index([parentId, status, position])
  @@index([status, position])

  @@unique([parentId, position])
}

model KnowledgeBaseBlock {
  id        String               @id @default(cuid())
  articleId String
  article   KnowledgeBaseArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  position  Int
  type      String
  payload   Json

  @@unique([articleId, position])
}

model InAppNotification {
  id            String                @id @default(cuid())
  userId        String
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryId    String?               @unique
  delivery      NotificationDelivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  domainEventId String
  eventType     String
  sourceId      String?
  category      NotificationCategory
  title         String
  body          String
  link          String?
  payload       Json?
  readAt        DateTime?
  archivedAt    DateTime?
  createdAt     DateTime              @default(now())

  @@unique([domainEventId, userId])
  @@index([userId, archivedAt, readAt])
  @@index([userId, createdAt])
}

model UserNotificationPreferences {
  id                   String                 @id @default(cuid())
  userId               String                 @unique
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  inAppMutedCategories NotificationCategory[] @default([])
  emailMutedCategories NotificationCategory[] @default([])
  updatedAt            DateTime               @updatedAt
}

model NotificationDelivery {
  id                String                     @id @default(cuid())
  domainEventId     String
  eventType         String
  recipientUserId   String
  recipient         User                       @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  channel           NotificationChannel
  address           String?
  status            NotificationDeliveryStatus @default(queued)
  attempt           Int                        @default(0)
  providerMessageId String?
  providerErrorCode String?
  providerErrorText String?
  queuedAt          DateTime                   @default(now())
  finishedAt        DateTime?
  inAppNotification InAppNotification?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@unique([domainEventId, recipientUserId, channel])
  @@index([recipientUserId, createdAt])
  @@index([status, createdAt])
}

model ModerationCase {
  id              String               @id @default(cuid())
  type            ModerationCaseType   @default(complaint)
  entityType      String
  entityId        String
  entityAuthorId  String?
  entityCompanyId String?
  status          ModerationCaseStatus @default(open)
  lockedById      String?
  lockedUntil     DateTime?
  complaints      Complaint[]
  decisions       ModerationDecision[]
  sanctions       Sanction[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  closedAt        DateTime?

  @@index([status, createdAt])
  @@index([entityType, entityId, status])
  @@index([lockedById, lockedUntil])
}

model Complaint {
  id              String          @id @default(cuid())
  caseId          String
  case            ModerationCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  entityType      String
  entityId        String
  authorId        String
  authorCompanyId String?
  reasonCode      String
  comment         String?
  status          ComplaintStatus @default(pending)
  createdAt       DateTime        @default(now())

  @@unique([entityType, entityId, authorId, reasonCode])
  @@index([caseId, status])
}

model ModerationDecision {
  id         String                 @id @default(cuid())
  caseId     String
  case       ModerationCase         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  actorId    String
  actorRole  String
  type       ModerationDecisionType
  reasonCode String
  comment    String?
  sanctions  Sanction[]
  createdAt  DateTime               @default(now())

  @@index([caseId, createdAt])
}

model Sanction {
  id                 String                  @id @default(cuid())
  caseId             String
  case               ModerationCase          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  decisionId         String?
  decision           ModerationDecision?     @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  type               SanctionType
  targetType         String
  targetId           String
  parameters         Json?
  appliedById        String
  appliedAt          DateTime                @default(now())
  liftedAt           DateTime?
  liftedById         String?
  moduleRestrictions UserModuleRestriction[]

  @@index([targetType, targetId, appliedAt])
  @@index([caseId, type])
}

model UserModuleRestriction {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId   String?
  moduleCode  String
  sanctionId  String?
  sanction    Sanction? @relation(fields: [sanctionId], references: [id], onDelete: SetNull)
  reasonCode  String
  comment     String?
  appliedById String
  appliedAt   DateTime  @default(now())
  expiresAt   DateTime
  liftedAt    DateTime?
  liftedById  String?

  @@index([userId, moduleCode, liftedAt, expiresAt])
  @@index([companyId, moduleCode])
}

model SupportTicket {
  id        String                 @id @default(cuid())
  authorId  String
  author    User                   @relation("SupportTicketAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  companyId String
  company   Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category  SupportTicketCategory
  subject   String
  status    SupportTicketStatus    @default(new)
  messages  SupportTicketMessage[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  // Списки: для компании — `where companyId, orderBy updatedAt desc`,
  // для админ-консоли модерации — `where status, orderBy updatedAt`.
  @@index([companyId, updatedAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
}

model SupportTicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  authorRole String
  text       String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())

  // Загрузка переписки тикета (chronological order).
  @@index([ticketId, createdAt])
}

model LegalDocument {
  id          String            @id @default(cuid())
  type        LegalDocumentType
  version     String
  title       String
  body        String
  summary     String?
  isRequired  Boolean           @default(true)
  isActive    Boolean           @default(false)
  publishedAt DateTime?
  consents    ConsentRecord[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([type, version])
  @@index([type, isActive])
  @@index([type, publishedAt(sort: Desc)])
}

model ConsentRecord {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId String
  document   LegalDocument @relation(fields: [documentId], references: [id])
  acceptedAt DateTime      @default(now())
  ipAddress  String?
  userAgent  String?
  source     ConsentSource @default(registration)

  @@unique([userId, documentId])
  @@index([userId, acceptedAt(sort: Desc)])
  @@index([documentId, acceptedAt(sort: Desc)])
}
