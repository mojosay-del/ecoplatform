  eventType     String
  sourceId      String?
  category      NotificationCategory
  title         String
  body          String
  link          String?
  payload       Json?
  readAt        DateTime?
  archivedAt    DateTime?
  createdAt     DateTime              @default(now())

  @@unique([domainEventId, userId])
  @@index([userId, archivedAt, readAt])
  @@index([userId, createdAt])
  // Ретеншен: крон cleanup-stale-records удаляет прочитанные/архивные старше 180 дней.
  @@index([readAt])
  @@index([archivedAt])
