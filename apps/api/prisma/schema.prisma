  targetId           String
  parameters         Json?
  appliedById        String
  appliedAt          DateTime                @default(now())
  liftedAt           DateTime?
  liftedById         String?
  moduleRestrictions UserModuleRestriction[]

  @@index([targetType, targetId, appliedAt])
  @@index([caseId, type])
  // FK на решение (onDelete: SetNull) — ускоряет обнуление при удалении.
  @@index([decisionId])
}

model UserModuleRestriction {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId   String?
  moduleCode  String
  sanctionId  String?
  sanction    Sanction? @relation(fields: [sanctionId], references: [id], onDelete: SetNull)
  reasonCode  String
  comment     String?
  appliedById String
  appliedAt   DateTime  @default(now())
  expiresAt   DateTime
  liftedAt    DateTime?
  liftedById  String?

  @@index([userId, moduleCode, liftedAt, expiresAt])
  @@index([companyId, moduleCode])
  // FK на санкцию (onDelete: SetNull) — ускоряет обнуление при удалении.
  @@index([sanctionId])
}

model SupportTicket {
  id        String                 @id @default(cuid())
  authorId  String
  author    User                   @relation("SupportTicketAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  companyId String
  company   Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category  SupportTicketCategory
  subject   String
  status    SupportTicketStatus    @default(new)
  messages  SupportTicketMessage[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  // Списки: для компании — `where companyId, orderBy updatedAt desc`,
  // для админ-консоли модерации — `where status, orderBy updatedAt`.
  @@index([companyId, updatedAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  // FK на автора: каскадное удаление тикетов при удалении юзера.
  @@index([authorId])
}

model SupportTicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  authorRole String
  text       String
  isInternal Boolean       @default(false)
