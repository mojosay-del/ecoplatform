  @@unique([userId, documentId])
  @@index([userId, acceptedAt(sort: Desc)])
  @@index([documentId, acceptedAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────
// ТОРГОВАЯ ПЛОЩАДКА (закрытый аукцион)
//
// Модуль строится по фазам. Здесь — слой ОБЪЯВЛЕНИЙ (этап 1): заготовитель
// публикует объявление о продаже сырья с позициями, фото/видео и адресом.
// Предложения (Offer*) — фаза 3 (ниже). Отзывы (MarketplaceReview*) — фаза 4,
// отдельной аддитивной миграцией. Таблицы заводим по мере готовности кода фазы.
//
// Площадка доступна авторизованным пользователям. Подписка, роли участников
// сделки и модерационные ограничения проверяются сервисами. Модерация объявлений
// переиспользует полиморфные ModerationCase/Complaint/Sanction
// (entityType='marketplace_listing'), без новых таблиц.
// ─────────────────────────────────────────────────────────────────────────

enum ListingStatus {
  draft // создано, ещё не опубликовано
  active // опубликовано, идёт 14-дневный отсчёт
  archived // снято: продано / истёк срок / снято автором или модератором
}

// Форма поставки позиции: прессованные тюки или несортированная россыпь.
enum ListingPositionForm {
  pressed
  loose
}

model MarketplaceListing {
  id              String        @id @default(cuid())
  sellerCompanyId String
  sellerCompany   Company       @relation("CompanyListings", fields: [sellerCompanyId], references: [id], onDelete: Cascade)
  // User внутри компании, опубликовавший объявление (аудит + «мои объявления»).
  createdById     String
  status          ListingStatus @default(draft)

  // Снимок адреса на момент создания: адрес компании может измениться, а у
  // объявления он зафиксирован. Точные координаты — в Address.latitude/longitude.
  addressId String   @unique
  address   Address  @relation("ListingAddress", fields: [addressId], references: [id])
  // Центр круга 4 км для публичной карты. Случайное смещение от реального адреса,
  // сгенерированное ОДИН раз при публикации и зафиксированное на всю жизнь
  // объявления — иначе сдвиг маркера между загрузками выдал бы точку. Точный
  // адрес раскрывается покупателю только после принятия предложения (фаза 3).
  circleLat Decimal? @db.Decimal(10, 7)
  circleLon Decimal? @db.Decimal(10, 7)

  // Контактный телефон вводится вручную (не из профиля) и раскрывается покупателю
  // только после акцепта предложения.
  contactPhone  String
  description   String?
  paymentTerms  String?
  // Типичный объём отгрузки в одну машину. Храним в кг (как weightKg позиций),
  // фронт вводит/показывает в тоннах. Опционально.
  typicalLoadKg Decimal?  @db.Decimal(12, 2)
  // Готовность к отгрузке: «готово сейчас» либо дата в пределах 14 дней.
  readyNow      Boolean   @default(true)
  readinessDate DateTime?

  publishedAt   DateTime?
  // publishedAt + 14 дней. По истечении cron переводит объявление в archived.
  expiresAt     DateTime?
  archivedAt    DateTime?
  // 'sold' | 'expired' | 'withdrawn' | 'removed_by_moderator' | 'not_settled'.
  // Строкой, а не enum — по соглашению проекта (ср. Payment.purpose).
  archiveReason String?

  positions ListingPosition[]
  media     ListingMedia[]
  offers    Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Публичная лента: активные объявления, свежие сверху.
  @@index([status, publishedAt(sort: Desc)])
  // «Мои объявления» компании.
  @@index([sellerCompanyId, status, createdAt(sort: Desc)])
  // Cron авто-архива: where status=active AND expiresAt < now.
  @@index([status, expiresAt])
}

model ListingPosition {
  id                     String              @id @default(cuid())
  listingId              String
  listing                MarketplaceListing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  nomenclatureId         String
  nomenclature           Nomenclature        @relation(fields: [nomenclatureId], references: [id])
  position               Int
  // Минимум 100 кг агрегатно по объявлению — проверяется в сервисе.
  weightKg               Decimal             @db.Decimal(12, 2)
  form                   ListingPositionForm @default(loose)
  packaging              String?
  moistureCondition      String?
  contaminationCondition String?
  offerPositions         OfferPosition[]
  createdAt              DateTime            @default(now())

  @@unique([listingId, position])
  @@index([nomenclatureId])
}

model ListingMedia {
  id        String             @id @default(cuid())
  listingId String
  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  // FileAsset.id. Учёт ссылок для очистки — через FileReference(entityType='marketplace_listing').
  fileId    String
  // 'photo' | 'video'. 4–10 фото и 0–2 видео — проверяется в сервисе.
  kind      String
  position  Int
  createdAt DateTime           @default(now())

  @@unique([listingId, position])
  @@index([fileId])
}

// ── Предложения (фаза 3): закрытый аукцион ────────────────────────────────
// Покупатель (трейдер/переработчик) шлёт закрытое ценовое предложение по
// позициям объявления. Имена скрыты до акцепта; контакты раскрываются продавцу
// и покупателю только после принятия. Принятие даёт 24ч на решение
// «Договорились/Не договорились»; иначе cron архивирует объявление (not_settled).
// Принятие/решение храним прямо на Offer (отдельной таблицы acceptance нет).

enum OfferStatus {
  active // подано, ждёт решения продавца
  withdrawn // отозвано покупателем до акцепта
  accepted // принято продавцом — контакты раскрыты, идёт 24ч-окно решения
  declined // отклонено: «не договорились», выбран другой, или объявление снято
}

enum PriceCondition {
  from_place // «цена с места» — покупатель вывозит сам
  at_gate // «цена на воротах» — продавец доставляет в город покупателя
}

enum DealResult {
  agreed // «Договорились» — сделка состоялась, объявление в архив (продано)
  not_agreed // «Не договорились» — объявление остаётся активным
}

model Offer {
  id             String             @id @default(cuid())
  listingId      String
  listing        MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerCompanyId String
  buyerCompany   Company            @relation("CompanyOffers", fields: [buyerCompanyId], references: [id], onDelete: Cascade)
  createdById    String
  status         OfferStatus        @default(active)
  priceCondition PriceCondition
  // Город покупателя для «цена на воротах» (куда продавец везёт).
  // До акцепта точный город скрыт от продавца; публично показываем только
  // регион, если он не раскрывает город.
  city           String?
  region         String?
  // Телефон покупателя; раскрывается продавцу только после акцепта.
  contactPhone   String

  // Принятие и решение (folded — отдельной таблицы acceptance нет). null пока не принято.
  acceptedAt       DateTime?
  decisionDeadline DateTime? // acceptedAt + 24ч; cron архивирует объявление, если решение не принято
  dealResult       DealResult?
  resolvedAt       DateTime? // когда зафиксировано решение или истёк дедлайн

  positions OfferPosition[]
  reviews   MarketplaceReview[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  // Лента предложений по объявлению (продавцу) + проверка «активный/принятый на объявление».
  @@index([listingId, status])
  // «Мои предложения» покупателя.
  @@index([buyerCompanyId, status, createdAt(sort: Desc)])
  // Cron авто-разрешения: where status=accepted, dealResult=null, decisionDeadline < now.
  @@index([status, decisionDeadline])
}

model OfferPosition {
  id                String          @id @default(cuid())
  offerId           String
  offer             Offer           @relation(fields: [offerId], references: [id], onDelete: Cascade)
  listingPositionId String
  listingPosition   ListingPosition @relation(fields: [listingPositionId], references: [id], onDelete: Cascade)
  // Цена за тонну (₽). null = «не интересует» эту позицию.
  pricePerTonRub    Int?
  createdAt         DateTime        @default(now())

  @@unique([offerId, listingPositionId])
  @@index([listingPositionId])
}

// ── Отзывы и рейтинг (фаза 4): мультикритерий, направленные ───────────────
// Отзыв оставляется по состоявшейся сделке (Offer с dealResult=agreed), обе
// стороны оценивают друг друга. Критерии РАЗНЫЕ по направлению (решение
// владельца): покупатель→продавца — quality/weight_accuracy/shipping_speed/
// reliability; продавец→покупателя — payment_speed/terms_adherence/reliability.
// Рейтинг компании усредняется «по-яндексовски» со служебным старт-5★ и кэшируется
// в CompanyMarketplaceRating (пересчёт при публикации/снятии отзыва).

enum ReviewDirection {
  buyer_to_seller // покупатель оценивает продавца
  seller_to_buyer // продавец оценивает покупателя
}

enum ReviewStatus {
  published
  hidden_by_moderator
  removed_by_author
}

enum ReviewCriterion {
  quality // покупатель→продавца: качество / соответствие описанию
  weight_accuracy // покупатель→продавца: точность веса и объёма
  shipping_speed // покупатель→продавца: скорость отгрузки
  payment_speed // продавец→покупателя: скорость оплаты
  terms_adherence // продавец→покупателя: соблюдение договорённостей
  reliability // общий: надёжность и коммуникация
}

model MarketplaceReview {
  id            String                     @id @default(cuid())
  offerId       String
  offer         Offer                      @relation(fields: [offerId], references: [id], onDelete: Cascade)
  direction     ReviewDirection
  fromCompanyId String
  fromCompany   Company                    @relation("ReviewsAuthored", fields: [fromCompanyId], references: [id], onDelete: Cascade)
  toCompanyId   String
  toCompany     Company                    @relation("ReviewsReceived", fields: [toCompanyId], references: [id], onDelete: Cascade)
  createdById   String
  comment       String?
  status        ReviewStatus               @default(published)
  // Окно правки/удаления автором — 3 минуты с создания (проверяется в сервисе).
  editableUntil DateTime
  scores        MarketplaceReviewScore[]
  response      MarketplaceReviewResponse?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  // По сделке (offer) одна сторона оставляет один отзыв.
  @@unique([offerId, direction])
  // Лента отзывов о компании + пересчёт рейтинга.
  @@index([toCompanyId, status, createdAt(sort: Desc)])
  @@index([fromCompanyId])
}

model MarketplaceReviewScore {
  id        String            @id @default(cuid())
  reviewId  String
  review    MarketplaceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  criterion ReviewCriterion
  score     Int // 1..5

  @@unique([reviewId, criterion])
}

model MarketplaceReviewResponse {
  id          String            @id @default(cuid())
  reviewId    String            @unique
  review      MarketplaceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdById String
  text        String
  createdAt   DateTime          @default(now())
}

// Кэш агрегата рейтинга компании. overall — среднее «общих баллов» отзывов +
// служебный старт-5★ (показывать только при reviewCount>0). byCriterion — JSON
// { criterion: { avg, count } } по критериям, релевантным типу компании.
model CompanyMarketplaceRating {
  companyId   String   @id
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  overall     Decimal  @db.Decimal(3, 2)
  reviewCount Int      @default(0)
  byCriterion Json
  updatedAt   DateTime @updatedAt
}

// Индивидуальные настройки розничного калькулятора рейса — один JSON-блок на
// компанию-заготовителя (парк машин, бригада, цена топлива, цены сырья).
// Валидация блока — packages/shared/src/trip-calculator.ts, UI — apps/web/src/
// views/calculators. Per-company: сотрудники компании делят один набор.
model CompanyTripCalculatorSettings {
  companyId String   @id
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Форум (Q&A сообщества): вопрос → ответы → принятое решение ─────────────
// Не чат, а searchable «память отрасли»: навигация = поиск + две оси-справочника
// (Вид сырья, Тип вопроса), которые ведёт админ из CMS. Тело вопроса/ответа —
// простой текст (String), не блоки. Репутация автора берётся из marketplace
// (CompanyMarketplaceRating + сделки Offer.dealResult=agreed) и собственной
// метрики «решено на форуме»; здесь не дублируется. Авторские поля — плоские
// *Id-строки (как createdById у новостей), без relation на User/Company:
// контент переживает удаление пользователя, как и в остальных разделах.

enum ForumQuestionStatus {
  open // нужен ответ — ответов ещё нет
  answered // есть ответы, решение автором не выбрано
  solved // автор отметил лучший ответ (acceptedAnswerId)
  hidden // снят модератором (remove_content из очереди модерации)
}

// Справочник «Вид сырья» — отдельная ось форума, НЕ связана с номенклатурой
// других разделов. Значения создаёт/правит/удаляет админ. При удалении значения
// тег у вопросов обнуляется (onDelete: SetNull), сам вопрос остаётся (ТЗ §6).
model ForumRawMaterial {
  id        String          @id @default(cuid())
  label     String          @unique
  position  Int
  questions ForumQuestion[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([position])
}

// Справочник «Тип вопроса» — вторая ось. Сидируется дефолтами
// (Регуляторика/Логистика/Оборудование/Цены и рынок/Документы), редактируется админом.
model ForumQuestionType {
  id        String          @id @default(cuid())
  label     String          @unique
  position  Int
  questions ForumQuestion[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([position])
}

model ForumQuestion {
  id               String              @id @default(cuid())
  authorId         String
  authorCompanyId  String?
  title            String
  body             String
  // Обе оси nullable: при удалении значения справочника тег обнуляется, вопрос
  // живёт дальше с одним тегом или без (ТЗ §6). UI/фильтры работают с null.
  rawMaterialId    String?
  rawMaterial      ForumRawMaterial?   @relation(fields: [rawMaterialId], references: [id], onDelete: SetNull)
  questionTypeId   String?
  questionType     ForumQuestionType?  @relation(fields: [questionTypeId], references: [id], onDelete: SetNull)
  status           ForumQuestionStatus @default(open)
  views            Int                 @default(0)
  // Денормализованный счётчик — лента/сортировки без агрегата на каждый запрос.
  answersCount     Int                 @default(0)
  // Принятый ответ (без relation, чтобы не плодить цикл question↔answer); на
  // стороне ответа дублируется флагом isAccepted, синхронно в транзакции.
  acceptedAnswerId String?
  // Момент перехода в solved — для метрики «время до решения» (ТЗ §11).
  solvedAt         DateTime?
  answers          ForumAnswer[]
  subscriptions    ForumSubscription[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  // Лента: orderBy createdAt desc с фильтром по статусу.
  @@index([status, createdAt(sort: Desc)])
  // Фильтры по осям.
  @@index([rawMaterialId])
  @@index([questionTypeId])
  // «Мои вопросы» / связка с автором.
  @@index([authorId])
}

model ForumAnswer {
  id              String            @id @default(cuid())
  questionId      String
  question        ForumQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  parentAnswerId  String?
  parentAnswer    ForumAnswer?      @relation("ForumAnswerThread", fields: [parentAnswerId], references: [id], onDelete: Cascade)
  replies         ForumAnswer[]     @relation("ForumAnswerThread")
  authorId        String
  authorCompanyId String?
  body            String
  votesCount      Int               @default(0)
  isAccepted      Boolean           @default(false)
  // Скрыт модератором (remove_content). У ответа нет статус-энума — достаточно флага.
  hidden          Boolean           @default(false)
  votes           ForumAnswerVote[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Список ответов «сначала лучшие».
  @@index([questionId, votesCount(sort: Desc)])
  // Ветки обсуждения под ответами: верхний уровень parentAnswerId=null, реплики — по parentAnswerId.
  @@index([questionId, parentAnswerId, hidden, createdAt(sort: Asc)])
  // Метрика «решено на форуме» по автору (groupBy where isAccepted).
  @@index([authorId, isAccepted])
  @@index([parentAnswerId])
}

model ForumAnswerVote {
  id        String      @id @default(cuid())
  answerId  String
  answer    ForumAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime    @default(now())

  // Один пользователь — один голос «полезно» за ответ (без даунвотов).
  @@unique([answerId, userId])
  @@index([userId])
}

model ForumSubscription {
  id         String        @id @default(cuid())
  questionId String
  question   ForumQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime      @default(now())

  // Подписка пользователя на вопрос (уведомления о новых ответах) — одна на пару.
  @@unique([questionId, userId])
  @@index([userId])
}
