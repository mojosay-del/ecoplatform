// Биллинг: способы оплаты (карта Тинькофф, банковский счёт) и статусы
// платежей. UI пока скрыт за заглушкой «Подключим в ближайшем обновлении»,
// но модели Payment/PaymentMethod (см. ниже) уже завязаны на эти enum'ы.
enum PaymentMethodType {
  card_tinkoff
  bank_invoice
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

// Полиморфные обсуждения: ветка комментариев привязывается не к конкретной
// сущности (NewsPost), а к Discussion с парой (targetType, targetId).
// Это позволяет лениво подключать комментарии к урокам, статьям базы знаний,
// объявлениям торговой площадки и темам форума без расщепления Comment.
enum DiscussionTargetType {
  news_post
  lesson
  knowledge_article
  listing
  forum_thread
  solution_review
}

model User {
  id                         String                       @id @default(cuid())
  email                      String                       @unique
  phone                      String                       @unique
  firstName                  String
  lastName                   String
  gender                     UserGender?
  passwordHash               String
  status                     UserStatus                   @default(active)
  failedLoginAttempts        Int                          @default(0)
  failedLoginWindowStartedAt DateTime?
  lockedUntil                DateTime?
  deletionRequestedAt        DateTime?
  companyId                  String?
  company                    Company?                     @relation(fields: [companyId], references: [id])
  // Аватар пользователя — загруженное им публичное изображение (FileAsset).
  // null → нейтральная иконка-заглушка на фронте. Пол (gender) больше НЕ
  // участвует в выборе аватара: аватар либо свой, либо обезличенная иконка.
  avatarFileId               String?
  avatarFile                 FileAsset?                   @relation("UserAvatar", fields: [avatarFileId], references: [id], onDelete: SetNull)
  // Роль внутри компании. По умолчанию `member` (минимум прав): владельцем
  // становится только тот, кто создаёт компанию при регистрации, и
  // приглашающий явно проставляет роль приглашённому. Существующие
  // пользователи переведены в `owner` бэкфиллом в миграции (каждый из них —
  // единственный пользователь своей компании).
  companyRole                CompanyRole                  @default(member)
  platformStaff              PlatformStaff?
  sessions                   Session[]
  newsLikes                  NewsLike[]
  comments                   Comment[]
  commentLikes               CommentLike[]
  lessonProgress             LessonProgress[]
  supportTickets             SupportTicket[]              @relation("SupportTicketAuthor")
  notifications              InAppNotification[]
  notificationDeliveries     NotificationDelivery[]       @relation("NotificationRecipient")
  notificationPreferences    UserNotificationPreferences?
  moduleRestrictions         UserModuleRestriction[]
  consents                   ConsentRecord[]
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt

  // FK на компанию. Postgres не индексирует FK автоматически. Нужен для
  // списка сотрудников компании (мультиюзер) и ускорения операций по companyId.
  @@index([companyId])
  @@index([status])
  @@index([lockedUntil])
  @@index([deletionRequestedAt])
  @@index([avatarFileId])
}

model EmailVerificationChallenge {
  id                  String      @id @default(cuid())
  email               String
  phone               String
  organizationName    String
  companyType         CompanyType
  firstName           String
  lastName            String
  passwordHash        String
  acceptedDocumentIds String[]    @default([])
  codeHash            String
  attempts            Int         @default(0)
  expiresAt           DateTime
  verifiedAt          DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([email, createdAt(sort: Desc)])
  @@index([phone, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model Company {
  id                       String                         @id @default(cuid())
  organizationName         String
  type                     CompanyType                    @default(collector)
  status                   CompanyStatus                  @default(demo)
  statusBeforeDeletion     CompanyStatus?
  demoEndsAt               DateTime?
  subscriptionPlan         SubscriptionPlan?
  subscriptionEndsAt       DateTime?
  // TODO (на вырост): per-seat биллинг пока не реализован в коде;
  // поле сохраняет будущую модель мест без миграции перед запуском.
  // Оплаченные «места» (per-seat). Сколько пользователей компании могут
  // одновременно иметь активный доступ. Владелец занимает первое место —
  // поэтому дефолт 1. Добавление сотрудника = докупленное место; при
  // подключении биллинга это число будет расти после оплаты. Денормализовано
  // на компанию (текущее состояние), история мест — в Subscription.seats.
  seatsPurchased           Int                            @default(1)
  billingInn               String?
  billingKpp               String?
  // Старое текстовое поле legalAddress оставлено для обратной совместимости
  // (на форму биллинга, где адрес показывается как одна строка). Полноценная
  // структура адреса — в Address (factualAddress/legalAddress relation'ами).
  legalAddress             String?
  factualAddressId         String?                        @unique
  factualAddress           Address?                       @relation("CompanyFactualAddress", fields: [factualAddressId], references: [id])
  structuredLegalAddressId String?                        @unique
  structuredLegalAddress   Address?                       @relation("CompanyStructuredLegalAddress", fields: [structuredLegalAddressId], references: [id])
  // Контакты компании. Все опциональные, заполняются в /account → Компания.
  websiteUrl               String?
  corporatePhone           String?
  corporateEmail           String?
  about                    String?
  // TODO (на вырост): загрузка/рендер логотипа компании пока не реализованы.
  logoFileId               String?
  // Контактное лицо: если у компании назначен «менеджер по входящим обращениям»
  // отличный от первого зарегистрированного user'а. В MVP — просто текстовые поля.
  contactPersonName        String?
  contactPersonPhone       String?
  contactPersonEmail       String?
  bankName                 String?
  bankBik                  String?
  bankAccount              String?
  correspondentAccount     String?
  users                    User[]
  invitations              CompanyInvitation[]
  subscriptions            Subscription[]
  supportTickets           SupportTicket[]
  paymentMethods           PaymentMethod[]
  payments                 Payment[]
  apiKeys                  ApiKey[]
  listings                 MarketplaceListing[]           @relation("CompanyListings")
  offers                   Offer[]                        @relation("CompanyOffers")
  reviewsAuthored          MarketplaceReview[]            @relation("ReviewsAuthored")
  reviewsReceived          MarketplaceReview[]            @relation("ReviewsReceived")
  marketplaceRating        CompanyMarketplaceRating?
  tripCalculatorSettings   CompanyTripCalculatorSettings?
  createdAt                DateTime                       @default(now())
  updatedAt                DateTime                       @updatedAt
}

// TODO (на вырост): модель пока не используется в коде — сохранённые
// способы оплаты для будущей интеграции платёжного провайдера.
//
// Сохранённый способ оплаты компании. В MVP UI заглушен «Подключим в
// ближайшем обновлении» — но модель уже стоит, чтобы при подключении
// Тинькофф-Кассы не пришлось двигать миграции с реальными платежами на
// проде. Маска карты и `providerToken` (рекуррентный токен) — единственное,
// что бэк хранит локально; PAN/CVV никогда не покидают платёжного провайдера.
model PaymentMethod {
  id            String            @id @default(cuid())
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type          PaymentMethodType
  cardMask      String?
  cardExpiry    String?
  providerToken String?
  isDefault     Boolean           @default(false)
  isActive      Boolean           @default(true)
  payments      Payment[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([companyId, isActive])
}

// TODO (на вырост): модель пока не используется в коде — ключи внешнего API
// для будущих ERP-интеграций.
//
// Ключи внешнего API компании (Волна 7.8). UI и эндпоинты для генерации/
// отзыва ключей в MVP не реализованы — только модель, чтобы при подключении
// внешнего ERP-интегратора был стабильный фундамент.
//
// Безопасность: храним bcrypt-hash секрета (`keyHash`), не сам секрет.
// При создании секрет возвращается один раз и больше нигде в БД не лежит.
// `scopes` — массив строк типа `news:read`, `indices:read` для будущего
// scope-based авторизатора.
model ApiKey {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  scopes     String[]  @default([])
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  createdBy  String

  @@index([companyId, isActive])
}

// История платежей компании. Сейчас пишется только из ручной активации
// подписки админом — будут попадать как `purpose=subscription_manual` после
// подключения Тинькофф-Кассы. UI заглушен empty-state'ом.
model Payment {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  amount          Decimal        @db.Decimal(12, 2)
  currency        String         @default("RUB")
  status          PaymentStatus  @default(pending)
  // Назначение платежа: 'subscription_initial' | 'subscription_renewal' |
  // 'product_purchase' | 'subscription_manual'. Строка, а не enum — чтобы
  // не плодить enum-расширения при появлении новых продуктов в магазине.
  purpose         String
  subscriptionId  String?
  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  providerName    String         @default("tinkoff_kassa")
  // TODO (на вырост): provider-поля пока не используются в коде — нужны для
  // будущей интеграции Тинькофф-Кассы, чеков, инвойсов и ошибок провайдера.
  providerOrderId String?        @unique
  providerError   String?
  receiptUrl      String?
  invoiceUrl      String?
  createdAt       DateTime       @default(now())
  paidAt          DateTime?

  @@index([companyId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  // FK на способ оплаты (onDelete: SetNull) — ускоряет обнуление при удалении.
  @@index([paymentMethodId])
}

// Address — самостоятельная сущность для адресов: и фактических, и юридических,
// и в перспективе адресов складов/филиалов/доставки/листингов торговой площадки.
// Хранит и raw-структуру (страна, регион, город, улица, дом, кв., индекс),
// и одну `formatted`-строку для отображения, и координаты под карту.
//
// source: 'manual' — пользователь ввёл руками; '2gis'/'dadata' — пришло
// из подсказки автокомплита (Волна 11+); 'legacy' — миграция старого
// текстового Company.legalAddress в одну `formatted`-строку.
model Address {
  id        String   @id @default(cuid())
  country   String   @default("Россия")
  region    String?
  city      String
  street    String?
  building  String?
  apartment String?
  postcode  String?
  // Координаты (Decimal(10,7) — точность до ~1 см, хватит и под Яндекс-карту,
  // и под кадастровые расчёты).
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  // Одна строка для UI — собирается из полей при сохранении или приходит
  // из автокомплита как авторитетное значение.
  formatted String
  source    String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyAsFactual   Company?            @relation("CompanyFactualAddress")
  companyAsLegal     Company?            @relation("CompanyStructuredLegalAddress")
  marketplaceListing MarketplaceListing? @relation("ListingAddress")
}

model Subscription {
  id        String             @id @default(cuid())
  companyId String
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(active)
  startsAt  DateTime
  endsAt    DateTime
  // Сколько мест оплачено в рамках этого периода подписки (per-seat).
  // Текущее (актуальное) значение продублировано в Company.seatsPurchased;
  // здесь — для истории, чтобы видеть, сколько мест было в каждом периоде.
  seats     Int                @default(1)
  reason    String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  // Биллинг-cron каждый час смотрит истёкшие подписки + у компании показывает
  // самую свежую («take: 1, orderBy createdAt desc»). Оба запроса попадают
  // под этот индекс.
  @@index([companyId, createdAt(sort: Desc)])
  @@index([status, endsAt])
}

// TODO (на вырост): модель пока не используется в коде — приглашения
// сотрудников в мультипользовательские компании.
//
// Приглашение сотрудника в компанию (мультипользовательские компании).
// Владелец (CompanyRole.owner) приглашает человека по email → тот
// регистрируется/принимает приглашение и привязывается к компании с ролью
// `member`. По безопасности храним bcrypt-hash токена приглашения
// (`tokenHash`), а не сам токен — по аналогии с EmailVerificationChallenge.
// Сам токен уходит в письмо/ссылку один раз и в БД не лежит.
//
// `invitedById` / `acceptedUserId` — это User.id; FK-связи намеренно нет
// (как у createdById/uploadedById в остальной схеме), чтобы удаление
// пригласившего не каскадило на историю приглашений.
//
// В MVP UI, рассылка писем и эндпоинты приёма не реализованы — модель
// заложена «на вырост». Срок жизни ограничен `expiresAt`; протухшие
// приглашения отбраковываются по статусу/крону.
model CompanyInvitation {
  id             String                  @id @default(cuid())
  companyId      String
  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email          String
  invitedById    String
  role           CompanyRole             @default(member)
  status         CompanyInvitationStatus @default(pending)
  tokenHash      String                  @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  acceptedUserId String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  // Список приглашений компании в админке/кабинете: where companyId+status.
  @@index([companyId, status])
  // Поиск приглашений по email при регистрации/принятии.
  @@index([email, status])
  // Крон отбраковки протухших приглашений.
  @@index([expiresAt])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  rememberMe       Boolean   @default(false)
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // FK на пользователя: список сессий, «выйти со всех устройств»
  // (updateMany по userId) и каскадное удаление при удалении юзера.
  @@index([userId])
  // Ретеншен: крон cleanup-stale-records удаляет истёкшие сессии по expiresAt.
  @@index([expiresAt])
}

model PlatformStaff {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles     PlatformRole[]
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model AdminActionLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  comment    String?
  payload    Json?
  createdAt  DateTime @default(now())

  // Ретеншен: крон cleanup-stale-records удаляет записи старше 2 лет по createdAt.
  @@index([createdAt])
  @@index([action, createdAt])
  @@index([entityType, createdAt])
  @@index([actorId, createdAt])
}

model IdempotencyKey {
  id            String   @id @default(cuid())
  key           String
  endpoint      String
  action        String
  actorId       String
  requestHash   String
  response      Json?
  referenceType String?
  referenceId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([key, endpoint, actorId])
  @@index([endpoint, createdAt])
  @@index([actorId, createdAt])
  @@index([referenceType, referenceId])
  // Ретеншен: крон cleanup-stale-records удаляет старые ключи по createdAt.
  @@index([createdAt])
}

model PlatformSetting {
  key         String   @id
  value       Json
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model FileAsset {
  id                    String                 @id @default(cuid())
  originalName          String
  mimeType              String
  sizeBytes             Int
  storageKey            String
  variants              Json?
  // Видео-ренишены (Волна полировки 2): перекодированные ffmpeg H.264/AAC MP4 в
  // 1–3 разрешениях для надёжного воспроизведения и выбора качества в плеере.
  // Формат: { status, renditions: [{ height, width, storageKey, sizeBytes }] }.
  // null — либо не видео, либо ещё не обработано.
  videoRenditions       Json?
  accessLevel           FileAccessLevel        @default(authenticated)
  uploadedById          String?
  createdAt             DateTime               @default(now())
  references            FileReference[]
  // Документы, у которых этот файл — основной скачиваемый (см. DocumentationArticle.file).
  documentationArticles DocumentationArticle[] @relation("DocumentationFile")
  // Пользователи, у которых этот файл выбран аватаром (см. User.avatarFile).
  avatarUsers           User[]                 @relation("UserAvatar")
}

// Полиморфная таблица «кто на какой файл ссылается». Content-блоки,
// документация и медиа объявлений ведут ссылки явно, поэтому
// `deleteIfUnreferenced` проверяет индексный `count({ where: { fileId } })`
// вместо scan всех JSON-payload.
//
// Поддерживается сервисами явно через `FilesService.replaceFileReferences()`.
// На прод-стенде дозаполняется backfill'ом по типам сущностей: новый тип
// не пропускается только из-за того, что в таблице уже есть строки других типов.
model FileReference {
  id         String    @id @default(cuid())
  fileId     String
  file       FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)
  // Сейчас: news_post, learning_module, knowledge_base_article,
  // documentation_article, marketplace_listing.
  entityType String
  entityId   String
  createdAt  DateTime  @default(now())

  // Один файл может быть упомянут только один раз в рамках одной сущности;
  // повторные ссылки внутри блоков схлопываются в одну строку.
  @@unique([fileId, entityType, entityId])
  @@index([fileId])
  @@index([entityType, entityId])
}

model NewsPost {
  id               String             @id @default(cuid())
  title            String
  lead             String
  coverImageId     String?
  slug             String             @unique
  status           ContentStatus      @default(draft)
  firstPublishedAt DateTime?
  createdById      String
  // «Закреплено в форуме»: новость-якорь показывается сверху ленты форума
  // (раздел «Форум»). Отдельной сущности «якорный пост» нет — это просто флаг
  // на новости, переключается из CMS-формы новостей. См. apps/api/src/forum.
  pinnedInForum    Boolean            @default(false)
  blocks           NewsContentBlock[]
  tags             NewsPostTag[]
  likes            NewsLike[]
  // Комментарии хранятся в Discussion(targetType=news_post, targetId=NewsPost.id).
  // FK прямого NewsPost↔Comment не существует — каскад удаления реализован в
  // news.service.ts (Discussion удаляется до NewsPost.delete).
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Главный публичный запрос — лента: `where status=published, orderBy firstPublishedAt desc`.
  // Без этого индекса Postgres сканирует всю таблицу новостей.
  @@index([status, firstPublishedAt(sort: Desc)])
  // Админка использует `orderBy updatedAt desc` — отдельный составной индекс.
  @@index([updatedAt(sort: Desc)])
  // Закреплённые в форуме новости: where status=published, pinnedInForum=true.
  @@index([status, pinnedInForum])
}

model NewsContentBlock {
  id         String   @id @default(cuid())
  newsPostId String
  newsPost   NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  position   Int
  type       String
  payload    Json

  @@unique([newsPostId, position])
}

model NewsTag {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  createdById String?
  usageCount  Int           @default(0)
  posts       NewsPostTag[]
  createdAt   DateTime      @default(now())
}

model NewsPostTag {
  newsPostId String
  newsTagId  String
  newsPost   NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  newsTag    NewsTag  @relation(fields: [newsTagId], references: [id], onDelete: Cascade)
  addedAt    DateTime @default(now())

  @@id([newsPostId, newsTagId])
  // FK на тег: «посты по тегу» и каскад при удалении тега. Составной PK
  // ведёт по newsPostId, поэтому второй FK (newsTagId) нужно индексировать.
  @@index([newsTagId])
}

model NewsLike {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newsPostId String
  newsPost   NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, newsPostId])
  // FK на пост: счётчик/выборка лайков поста и каскад при удалении поста.
  // Уникальный (userId, newsPostId) ведёт по userId и для запроса по
  // newsPostId не годится.
  @@index([newsPostId])
}

model Discussion {
  id         String               @id @default(cuid())
  targetType DiscussionTargetType
  targetId   String
  isLocked   Boolean              @default(false)
  comments   Comment[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([targetType, targetId])
  @@index([targetType, targetId])
}

model Comment {
  id              String              @id @default(cuid())
  discussionId    String
  discussion      Discussion          @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parentCommentId String?
  parentComment   Comment?            @relation("CommentThread", fields: [parentCommentId], references: [id])
  replies         Comment[]           @relation("CommentThread")
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  text            String
  status          CommentStatus       @default(published)
  attachments     CommentAttachment[]
  likes           CommentLike[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Главный запрос — дерево комментариев обсуждения: фильтрация по
  // (discussionId, parentCommentId=null, status=published), затем reply'ы.
  @@index([discussionId, parentCommentId, status, createdAt(sort: Desc)])
  @@index([parentCommentId, status, createdAt])
  // FK на автора: «мои комментарии» и каскадное удаление при удалении юзера.
  @@index([userId])
}

model CommentAttachment {
  id        String  @id @default(cuid())
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  fileId    String
  position  Int

  @@unique([commentId, position])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  // FK на комментарий: счётчик/выборка лайков и каскад при удалении коммента.
  @@index([commentId])
}

model Nomenclature {
