generator client {
  provider      = "prisma-client-js"
  // native       — локальная разработка (macOS arm64 / linux x64).
  // linux-musl-* — alpine-образы в Docker (наш прод-вариант).
  // debian-*     — запасной вариант, если перейдём на bookworm-slim.
  // Без этого `prisma generate` в Docker не подтянет нужный query engine.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  demo
  active
  past_due
  suspended
  pending_deletion
  blocked
  archived
}

enum SubscriptionPlan {
  basic
  extended
}

enum SubscriptionStatus {
  active
  past_due
  suspended
  cancelled
  expired
}

enum CompanyType {
  collector
  trader
  processor
}

enum UserGender {
  male
  female
}

enum PlatformRole {
  admin
  moderator
  content_manager
}

// Роль пользователя ВНУТРИ его компании (не путать с PlatformRole —
// это роль сотрудника платформы). `owner` — тот, кто зарегистрировал
// компанию: управляет составом сотрудников, биллингом и местами (seats),
// приглашает других. `member` — приглашённый сотрудник: пользуется
// доступом компании, но не управляет ей. На вырост: при появлении более
// тонких прав внутри компании сюда добавятся новые значения (например,
// billing_manager) без расщепления модели User.
enum CompanyRole {
  owner
  member
}

// Жизненный цикл приглашения сотрудника в компанию (см. модель
// CompanyInvitation). `pending` — отправлено, ждёт принятия; `accepted` —
// принято, пользователь привязан к компании; `revoked` — отозвано
// владельцем до принятия; `expired` — протухло по expiresAt (крон/ленивая
// проверка). UI и рассылка писем в MVP не реализованы — модель заложена
// «на вырост» под мультипользовательские компании.
enum CompanyInvitationStatus {
  pending
  accepted
  revoked
  expired
}

