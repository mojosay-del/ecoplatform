# ЭкоПлатформа — единая точка входа из интернета.
# Caddy сам получает и продлевает БЕСПЛАТНЫЙ HTTPS-сертификат (Let's Encrypt) —
# ничего вручную выпускать не нужно.
#
# Если домен не ecoplatform.pro — замените его в двух местах ниже.
{
	# Email для Let's Encrypt (уведомления об истечении сертификата).
	email mojosay@icloud.com
}

ecoplatform.pro {
	encode zstd gzip

	# Edge-default security headers. Upstream web/api can override them, but
	# every public response gets a safe baseline from the internet entrypoint.
	header {
		?Strict-Transport-Security "max-age=63072000; includeSubDomains"
		?X-Content-Type-Options "nosniff"
		?Referrer-Policy "strict-origin-when-cross-origin"
		?Permissions-Policy "camera=(), microphone=(), geolocation=()"
		?X-Frame-Options "DENY"
	}

	# Всё, что начинается с /api/ — отправляем в бэкенд (NestJS, контейнер api).
	handle /api/* {
		# JSON API не исполняет браузерные скрипты/стили, поэтому строгая
		# fallback-CSP безопасна и закрывает путь, где Helmet CSP выключен.
		header {
			?Content-Security-Policy "default-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none'"
		}

		reverse_proxy api:4000
	}

	# Всё остальное — на сайт (Next.js, контейнер web).
	handle {
		reverse_proxy web:3000
	}
}

# Заходящих на www.ecoplatform.pro мягко переводим на адрес без www.
www.ecoplatform.pro {
	redir https://ecoplatform.pro{uri} permanent
}
