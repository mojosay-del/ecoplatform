# ════════════════════════════════════════════════════════════════════════
# ПРОД-ПЕРЕМЕННЫЕ ЭкоПлатформы (шаблон).
#
# КАК ПОЛЬЗОВАТЬСЯ:
#   1. Скопировать в реальный файл:   cp deploy/.env.prod.example deploy/.env.prod
#   2. Заполнить все значения "replace-with-...".
#   3. deploy/.env.prod НИКОГДА не коммитить (он уже в .gitignore) и не
#      выкладывать никуда — это секреты.
# ════════════════════════════════════════════════════════════════════════

# ── База данных (Timeweb Managed PostgreSQL) ─────────────────────────────
# USER/PASSWORD/HOST/PORT/DBNAME возьмите во вкладке «Подключение» кластера.
# sslmode=require ОБЯЗАТЕЛЕН (Timeweb требует TLS). connection_limit=20.
# Если сервер и БД в одной приватной сети Timeweb — берите приватный host.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public&sslmode=require&connection_limit=20"

# ── JWT-секреты (ОБЯЗАТЕЛЬНЫ, не короче 32 символов) ─────────────────────
# Без них API НЕ ЗАПУСТИТСЯ. Сгенерируйте два РАЗНЫХ:  openssl rand -hex 32
JWT_ACCESS_SECRET="replace-with-random-at-least-32-chars"
JWT_REFRESH_SECRET="replace-with-ANOTHER-random-at-least-32-chars"

# ── Публичные адреса ─────────────────────────────────────────────────────
# Один домен: сайт на корне, API под /api. Этот адрес «зашивается» в сайт
# при сборке — если меняете домен, пересоберите web.
NEXT_PUBLIC_API_URL="https://ecoplatform.pro/api"
# Публичный адрес сайта (CORS / cookies).
WEB_ORIGIN="https://ecoplatform.pro"

# ── S3 (Timeweb Cloud Storage) ───────────────────────────────────────────
S3_ENDPOINT="https://s3.twcstorage.ru"
S3_REGION="ru-1"
S3_BUCKET="replace-with-bucket-name"          # имя бакета, напр. bfe9c154-...
S3_ACCESS_KEY_ID="replace-with-access-key"
S3_SECRET_ACCESS_KEY="replace-with-secret-key"
S3_PUBLIC_BASE_URL="https://s3.twcstorage.ru"

# ── Владелец платформы (защищённый супер-админ) ──────────────────────────
PLATFORM_OWNER_EMAIL="mojosay@icloud.com"

# ── Метрики Prometheus (в проде закрыты Basic Auth) ──────────────────────
METRICS_BASIC_USER="prometheus"
METRICS_BASIC_PASSWORD="replace-with-long-random-password"

# ── Redis ────────────────────────────────────────────────────────────────
# Оставьте как есть, если используете контейнер redis из docker-compose.prod.yml.
# Если redis-контейнер удалили — очистите это значение (REDIS_URL="").
REDIS_URL="redis://redis:6379"

# ── Пароли учёток сидера (нужны ТОЛЬКО для первого `seed`) ───────────────
# Эти учётки потом удалит promote-first-admin — задайте любые надёжные (≥12).
SEED_ADMIN_PASSWORD="replace-with-strong-throwaway-at-least-12"
SEED_DEMO_PASSWORD="replace-with-strong-throwaway-at-least-12"

# ── Прочее ───────────────────────────────────────────────────────────────
LOG_LEVEL="info"
PWNED_PASSWORDS_CHECK_ENABLED="1"
# Торговая площадка: 1 — открыта всем авторизованным пользователям,
# выключенный флаг — только платформенным админам для служебной проверки.
MARKETPLACE_ENABLED="1"

# ── SMTP для подтверждения почты при регистрации ─────────────────────────
SMTP_HOST="smtp.timeweb.ru"
SMTP_PORT="465"
SMTP_SECURE="1"
SMTP_USER="notify@ecoplatform.pro"
SMTP_PASS="replace-with-smtp-password"
SMTP_FROM="ЭкоПлатформа <notify@ecoplatform.pro>"
# Отдельный секрет HMAC для 4-значных кодов. Если не задан, используется JWT_ACCESS_SECRET.
# EMAIL_VERIFICATION_SECRET="replace-with-random-at-least-32-chars"

# ── Sentry (необязательно — отслеживание ошибок) ─────────────────────────
# SENTRY_DSN_API=""
# SENTRY_DSN_WEB=""
# NEXT_PUBLIC_SENTRY_DSN=""
