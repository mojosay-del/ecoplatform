# syntax=docker/dockerfile:1
# Multi-stage сборка Next.js web внутри pnpm + Turborepo.
# Сборка из КОРНЯ репозитория: `docker build -f apps/web/Dockerfile .`

ARG NODE_VERSION=24
# Реестр базовых образов. По умолчанию — обычный Docker Hub (работает везде).
# На Timeweb App Platform переопределяется на их зеркало через build-arg в
# docker-compose.yml (Docker Hub из РФ режется по скорости до ~25 КБ/с).
ARG IMAGE_REGISTRY=docker.io/library

# ────────────────── Stage 1: deps ──────────────────
FROM ${IMAGE_REGISTRY}/node:${NODE_VERSION}-alpine AS deps
RUN sed -i 's#dl-cdn.alpinelinux.org/alpine#mirror.yandex.ru/mirrors/alpine#g' /etc/apk/repositories && apk add --no-cache libc6-compat
# Corepack на VPS нестабилен с default registry.npmjs.org; зеркало проверено
# с production-сервера перед деплоем.
ENV COREPACK_NPM_REGISTRY=https://registry.yarnpkg.com
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /repo

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
# Сеть до npm-реестра с этого сервера бывает нестабильной (таймауты тарболлов):
# повышаем ретраи/таймаут, снижаем параллелизм и до 5 раз повторяем всю установку.
RUN pnpm config set fetch-retries 8 && \
    pnpm config set fetch-retry-maxtimeout 120000 && \
    pnpm config set network-concurrency 4 && \
    for i in 1 2 3 4 5; do pnpm install --frozen-lockfile && break; \
      if [ "$i" = 5 ]; then echo "pnpm install: все попытки исчерпаны"; exit 1; fi; \
      echo "pnpm install: повтор $i после сетевого сбоя"; sleep 15; done

# ────────────────── Stage 2: build ──────────────────
FROM ${IMAGE_REGISTRY}/node:${NODE_VERSION}-alpine AS build
RUN sed -i 's#dl-cdn.alpinelinux.org/alpine#mirror.yandex.ru/mirrors/alpine#g' /etc/apk/repositories && apk add --no-cache libc6-compat
ENV COREPACK_NPM_REGISTRY=https://registry.yarnpkg.com
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /repo

# Тянем из deps ВСЁ дерево с node_modules (включая per-package симлинки pnpm),
# иначе shared не найдёт zod/isomorphic-dompurify. Затем накладываем исходники.
COPY --from=deps /repo ./
COPY . .

# NEXT_PUBLIC_* читаются на build-time — пробрасываем как build-arg.
ARG NEXT_PUBLIC_API_URL="http://localhost:4000/api"
# Карта MapLibre: стиль (self-host на проде) и origin тайлов для CSP. Пусто →
# фронт берёт dev-fallback OpenFreeMap positron.
ARG NEXT_PUBLIC_MAP_STYLE_URL=""
ARG NEXT_PUBLIC_MAP_TILES_ORIGIN=""
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_MAP_STYLE_URL=${NEXT_PUBLIC_MAP_STYLE_URL}
ENV NEXT_PUBLIC_MAP_TILES_ORIGIN=${NEXT_PUBLIC_MAP_TILES_ORIGIN}

# Сначала shared (через turbo dependsOn), потом сам next build.
RUN pnpm --filter @ecoplatform/web... build

# ────────────────── Stage 3: runtime ──────────────────
FROM ${IMAGE_REGISTRY}/node:${NODE_VERSION}-alpine AS runtime
RUN sed -i 's#dl-cdn.alpinelinux.org/alpine#mirror.yandex.ru/mirrors/alpine#g' /etc/apk/repositories && apk add --no-cache libc6-compat tini
WORKDIR /app

ENV NODE_ENV=production \
    TZ=UTC \
    PORT=3000 \
    HOSTNAME=0.0.0.0

RUN addgroup -S nodeapp && adduser -S nodeapp -G nodeapp

# `output: "standalone"` собирает в .next/standalone минимум зависимостей.
# Структура — apps/web/server.js + node_modules. С outputFileTracingRoot
# на корне репозитория standalone лежит в .next/standalone полным деревом.
COPY --from=build --chown=nodeapp:nodeapp /repo/apps/web/.next/standalone ./
COPY --from=build --chown=nodeapp:nodeapp /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=nodeapp:nodeapp /repo/apps/web/public ./apps/web/public

USER nodeapp
EXPOSE 3000
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "apps/web/server.js"]
