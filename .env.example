# Локальный Postgres из docker-compose.yml слушает :5433 (5432 часто занят
# системным Postgres на macOS). Для прод-деплоя поменяйте host/port + добавьте
# `&sslmode=require` — Timeweb Managed Postgres требует TLS. Для API оставляйте
# `connection_limit=20`, чтобы одна реплика не забирала весь пул Postgres.
DATABASE_URL="postgresql://ecoplatform:ecoplatform@localhost:5433/ecoplatform?schema=public&connection_limit=20"

# JWT-секреты ОБЯЗАТЕЛЬНЫ и должны быть не короче 32 символов: иначе
# приложение не стартует (см. assertSecret в apps/api/src/main.ts).
# Сгенерируйте свежие: `openssl rand -hex 32`.
JWT_ACCESS_SECRET="replace-with-local-access-secret-at-least-32-chars-long"
JWT_REFRESH_SECRET="replace-with-local-refresh-secret-at-least-32-chars-long"

NEXT_PUBLIC_API_URL="http://localhost:4000/api"
API_PORT="4000"
WEB_PORT="3000"

# Уровень логов API: trace/debug/info/warn/error/fatal/silent.
# По умолчанию dev=debug, prod=info, test=silent.
# LOG_LEVEL="debug"

# Sentry error tracking. DSN — публичный идентификатор проекта. Auth-token,
# org и project нужны только в CI, чтобы включить build-plugin и sourcemap upload.
# Auth-token — секрет, его нельзя коммитить в реальные env.
SENTRY_DSN_API=""
SENTRY_DSN_WEB=""
NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="api-project"
# SENTRY_PROJECT_WEB="web-project"
# SENTRY_AUTH_TOKEN=""
# SENTRY_ENVIRONMENT="local"
# NEXT_PUBLIC_SENTRY_ENVIRONMENT="local"
# SENTRY_TRACES_SAMPLE_RATE="0"
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0"
# GIT_SHA="dev"

# Redis — ускоряет auth guard, rate-limit и будущий кеш публичного контента.
# Если Redis недоступен или REDIS_URL пустой, API продолжает работать через БД
# и in-memory throttler.
REDIS_URL="redis://localhost:6379"

# Проверка новых паролей через Have I Been Pwned Pwned Passwords range API.
# Отправляются только первые 5 символов SHA-1-хэша; plaintext-пароль не покидает API.
PWNED_PASSWORDS_CHECK_ENABLED="1"
# PWNED_PASSWORDS_TIMEOUT_MS="1500"
# PWNED_PASSWORDS_USER_AGENT="EcoPlatform/1.0"

# CORS origin фронтенда. В проде — публичный URL вашего web-приложения.
# WEB_ORIGIN="https://app.ecoplatform.ru"

# S3-совместимое хранилище (Timeweb Cloud Storage).
S3_ENDPOINT="https://s3.twcstorage.ru"
S3_REGION="ru-1"
S3_BUCKET="replace-with-bucket-name"
S3_ACCESS_KEY_ID="replace-with-access-key"
S3_SECRET_ACCESS_KEY="replace-with-secret-key"
S3_PUBLIC_BASE_URL="https://s3.twcstorage.ru"

# Email «первого админа» — этого аккаунта нельзя ни деактивировать,
# ни снять с него роль admin через admin-UI (защита от случайного блокирования
# единственного супер-пользователя). Также скрипт `promote-first-admin.ts`
# назначает на него авторство всего контента при чистке БД.
# По умолчанию — mojosay@icloud.com.
# PLATFORM_OWNER_EMAIL="mojosay@icloud.com"

# Отключение rate-limit (нужно только в integration-тестах).
# THROTTLER_DISABLED="1"

# Отключение cron-задач биллинга (нужно только в тестах).
# SCHEDULER_DISABLED="1"
