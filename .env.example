# Локальный Postgres из docker-compose.yml слушает :5433 (5432 часто занят
# системным Postgres на macOS). Для прод-деплоя поменяйте host/port + добавьте
# `&sslmode=require` — Timeweb Managed Postgres требует TLS. Для API оставляйте
# `connection_limit=20`, чтобы одна реплика не забирала весь пул Postgres.
DATABASE_URL="postgresql://ecoplatform:ecoplatform@localhost:5433/ecoplatform?schema=public&connection_limit=20"

# JWT-секреты ОБЯЗАТЕЛЬНЫ и должны быть не короче 32 символов: иначе
# приложение не стартует (см. assertSecret в apps/api/src/main.ts).
# Сгенерируйте свежие: `openssl rand -hex 32`.
JWT_ACCESS_SECRET="replace-with-local-access-secret-at-least-32-chars-long"
JWT_REFRESH_SECRET="replace-with-local-refresh-secret-at-least-32-chars-long"

# Пароли dev-учёток, которые создаёт `pnpm --filter @ecoplatform/api seed`.
# Реальные значения храните только в локальном .env / secret manager.
# SEED_ADMIN_PASSWORD="replace-with-local-admin-password-at-least-12-chars"
# SEED_DEMO_PASSWORD="replace-with-local-demo-password-at-least-12-chars"

NEXT_PUBLIC_API_URL="http://localhost:4000/api"
API_PORT="4000"
WEB_PORT="3000"

# OpenAPI/Swagger: в dev/test доступно по умолчанию на /api/docs и
# /api/openapi.json. В production публикуется только при OPENAPI_ENABLED=1.
# OPENAPI_ENABLED="1"

# Уровень логов API: trace/debug/info/warn/error/fatal/silent.
# По умолчанию dev=debug, prod=info, test=silent.
# LOG_LEVEL="debug"

# Prometheus: в production `/api/metrics` требует Basic Auth.
# Пароль храните только в env/secrets, не в коде.
# METRICS_BASIC_USER="prometheus"
# METRICS_BASIC_PASSWORD="replace-with-long-random-password"

# Sentry error tracking. DSN — публичный идентификатор проекта. Auth-token,
# org и project нужны только в CI, чтобы включить build-plugin и sourcemap upload.
# Auth-token — секрет, его нельзя коммитить в реальные env.
SENTRY_DSN_API=""
SENTRY_DSN_WEB=""
NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="api-project"
# SENTRY_PROJECT_WEB="web-project"
# SENTRY_AUTH_TOKEN=""
# SENTRY_ENVIRONMENT="local"
# NEXT_PUBLIC_SENTRY_ENVIRONMENT="local"
# SENTRY_TRACES_SAMPLE_RATE="0"
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0"
# GIT_SHA="dev"

# Redis — ускоряет auth guard, rate-limit и будущий кеш публичного контента.
# Если Redis недоступен или REDIS_URL пустой, API продолжает работать через БД
# и in-memory throttler.
REDIS_URL="redis://localhost:6379"

# Проверка новых паролей через Have I Been Pwned Pwned Passwords range API.
# Отправляются только первые 5 символов SHA-1-хэша; plaintext-пароль не покидает API.
PWNED_PASSWORDS_CHECK_ENABLED="1"
# PWNED_PASSWORDS_TIMEOUT_MS="1500"
# PWNED_PASSWORDS_USER_AGENT="EcoPlatform/1.0"

# SMTP для регистрационного кода подтверждения почты.
# Пароль храните только в локальном .env / deploy secrets, не в git.
#
# ⚠️ DEV-ИЗОЛЯЦИЯ: для локальной разработки НЕ подключайте боевой ящик
# notify@ecoplatform.pro — регистрация шлёт реальные письма с прод-адреса.
# Используйте локальный sink (mailpit/MailHog: SMTP_HOST=localhost, SMTP_PORT=1025,
# SMTP_SECURE=0) или отдельный тестовый ящик. Боевые значения — только в
# deploy/.env.prod на сервере.
SMTP_HOST="smtp.timeweb.ru"
SMTP_PORT="465"
SMTP_SECURE="1"
SMTP_USER="notify@ecoplatform.pro"
SMTP_PASS="replace-with-smtp-password"
SMTP_FROM="ЭкоПлатформа <notify@ecoplatform.pro>"
# Короткие таймауты SMTP не дают регистрации висеть на «Отправляем код…», если
# почтовый сервер долго не отвечает.
# SMTP_CONNECTION_TIMEOUT_MS="8000"
# SMTP_GREETING_TIMEOUT_MS="5000"
# SMTP_SOCKET_TIMEOUT_MS="8000"
# SMTP_DNS_TIMEOUT_MS="5000"
# SMTP_SEND_TIMEOUT_MS="10000"
# Отдельный секрет HMAC для 4-значных кодов. Если не задан, используется JWT_ACCESS_SECRET.
# EMAIL_VERIFICATION_SECRET="replace-with-random-at-least-32-chars"

# CORS allowlist фронтенда. Несколько origin'ов перечисляются через запятую.
# В проде обязательно укажите публичный домен без localhost.
WEB_ORIGINS="http://localhost:3000"
# WEB_ORIGINS="https://ecoplatform.pro,https://www.ecoplatform.pro"

# S3-совместимое хранилище (Timeweb Cloud Storage).
# S3_BUCKET — ПУБЛИЧНЫЙ бакет (public-read): обложки, аватары, картинки контента.
#
# ⚠️ DEV-ИЗОЛЯЦИЯ: локально НЕ указывайте боевые бакеты/ключи. Загрузка, удаление
# (deleteIfUnreferenced) и backfill работают напрямую против указанного бакета —
# dev против прод-бакета может удалить/перезаписать файлы клиентов.
# Заведите ОТДЕЛЬНУЮ dev-пару бакетов (публичный + приватный) с собственными
# ключами, либо поднимите локальный MinIO (S3_ENDPOINT=http://localhost:9000).
# Боевые ключи — только в deploy/.env.prod на сервере.
S3_ENDPOINT="https://s3.twcstorage.ru"
S3_REGION="ru-1"
S3_BUCKET="replace-with-bucket-name"
S3_ACCESS_KEY_ID="replace-with-access-key"
S3_SECRET_ACCESS_KEY="replace-with-secret-key"
S3_PUBLIC_BASE_URL="https://s3.twcstorage.ru"
# ПРИВАТНЫЙ бакет для платных вложений уроков (НЕ public-read). Файлы отдаются
# только короткоживущей presigned-ссылкой за paywall. Если переменная пуста —
# приватные файлы остаются в публичном бакете (старое поведение, без защиты).
# После первого включения один раз прогнать миграцию исторических вложений:
#   pnpm --filter @ecoplatform/api migrate:attachments-private
S3_PRIVATE_BUCKET="replace-with-private-bucket-name"

# Email «первого админа» — этого аккаунта нельзя ни деактивировать,
# ни снять с него роль admin через admin-UI (защита от случайного блокирования
# единственного супер-пользователя). Также скрипт `promote-first-admin.ts`
# назначает на него авторство всего контента при чистке БД.
# По умолчанию — mojosay@icloud.com.
# PLATFORM_OWNER_EMAIL="mojosay@icloud.com"

# Отключение rate-limit (нужно только в integration-тестах).
# THROTTLER_DISABLED="1"

# Отключение cron-задач биллинга (нужно только в тестах).
# SCHEDULER_DISABLED="1"

# ── Торговая площадка: карты (2ГИС) ───────────────────────────────────────
# Ключи берутся в кабинете platform.2gis.com; продукты MapGL JS API и Geocoder/
# Suggest подключаются к ключу по отдельности (один ключ можно включить на оба).
#
# Геокодер адресов объявлений (backend, СЕКРЕТ — в клиент не попадает). Без него
# объявления сохраняются без координат (на карте не показываются, список работает).
# Продукт «Geocoder API» (Catalog) в кабинете 2ГИС.
# DGIS_GEOCODER_API_KEY="replace-with-2gis-geocoder-key"
#
# Ключ карт MapGL (frontend, попадает в клиент — защищается привязкой к домену в
# кабинете 2ГИС, а не сокрытием). Может совпадать с геокодерным ключом.
# Без него на площадке вместо карты показывается список с заглушкой.
# NEXT_PUBLIC_DGIS_MAPS_API_KEY="replace-with-2gis-mapgl-key"
